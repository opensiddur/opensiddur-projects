      <tei:body>
         <tei:div type="book"
                  corresp="urn:x-opensiddur:text:bible:lamentations"
                  n="lamentations">
            <tei:head>איכה</tei:head>
            <tei:p type="open-1">
               <tei:milestone unit="chapter"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1"
                              n="1"/>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/1"
                              n="1"/>אֵיכָ֣ה ׀ יָשְׁבָ֣ה בָדָ֗ד הָעִיר֙ רַבָּ֣תִי עָ֔ם הָיְתָ֖ה כְּאַלְמָנָ֑ה רַּבָּ֣תִי בַגּוֹיִ֗ם שָׂרָ֙תִי֙ בַּמְּדִינ֔וֹת הָיְתָ֖ה לָמַֽס׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/2"
                              n="2"/>בָּכ֨וֹ תִבְכֶּ֜ה בַּלַּ֗יְלָה וְדִמְעָתָהּ֙ עַ֣ל לֶֽחֱיָ֔הּ אֵֽין־לָ֥הּ מְנַחֵ֖ם מִכָּל־אֹהֲבֶ֑יהָ כָּל־רֵעֶ֙יהָ֙ בָּ֣גְדוּ בָ֔הּ הָ֥יוּ לָ֖הּ לְאֹיְבִֽים׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/3"
                              n="3"/>גָּֽלְתָ֨ה יְהוּדָ֤ה מֵעֹ֙נִי֙ וּמֵרֹ֣ב עֲבֹדָ֔ה הִ֚יא יָשְׁבָ֣ה בַגּוֹיִ֔ם לֹ֥א מָצְאָ֖ה מָנ֑וֹחַ כָּל־רֹדְפֶ֥יהָ הִשִּׂיג֖וּהָ בֵּ֥ין הַמְּצָרִֽים׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/4"
                              n="4"/>דַּרְכֵ֨י צִיּ֜וֹן אֲבֵל֗וֹת מִבְּלִי֙ בָּאֵ֣י מוֹעֵ֔ד כָּל־שְׁעָרֶ֙יהָ֙ שֽׁוֹמֵמִ֔ין כֹּהֲנֶ֖יהָ נֶאֱנָחִ֑ים בְּתוּלֹתֶ֥יהָ נּ<tei:anchor xml:id="note-ref-lamentations-1-4-1"/>וּג֖וֹת וְהִ֥יא מַר־לָֽהּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/5"
                              n="5"/>הָי֨וּ צָרֶ֤יהָ לְרֹאשׁ֙ אֹיְבֶ֣יהָ שָׁל֔וּ כִּֽי־יְהוָ֥ה הוֹגָ֖הּ עַ֣ל רֹב־פְּשָׁעֶ֑יהָ עוֹלָלֶ֛יהָ הָלְכ֥וּ שְׁבִ֖י לִפְנֵי־צָֽר׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/6"
                              n="6"/>וַיֵּצֵ֥א <j:written>מן</j:written>
               <tei:choice>
                  <j:written>בת־</j:written>
                  <j:read>מִבַּת־</j:read>
               </tei:choice>צִיּ֖וֹן כָּל־הֲדָרָ֑הּ הָי֣וּ שָׂרֶ֗יהָ כְּאַיָּלִים֙ לֹא־מָצְא֣וּ מִרְעֶ֔ה וַיֵּלְכ֥וּ בְלֹא־כֹ֖חַ לִפְנֵ֥י רוֹדֵֽף׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/7"
                              n="7"/>זָֽכְרָ֣ה יְרוּשָׁלִַ֗ם יְמֵ֤י עָנְיָהּ֙ וּמְרוּדֶ֔יהָ כֹּ֚ל מַחֲמֻדֶ֔יהָ אֲשֶׁ֥ר הָי֖וּ מִ֣ימֵי קֶ֑דֶם בִּנְפֹ֧ל עַמָּ֣הּ בְּיַד־צָ֗ר וְאֵ֤ין עוֹזֵר֙ לָ֔הּ רָא֣וּהָ צָרִ֔ים שָׂחֲק֖וּ עַ֥ל מִשְׁבַּתֶּֽהָ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/8"
                              n="8"/>חֵ֤טְא חָֽטְאָה֙ יְר֣וּשָׁלִַ֔ם עַל־כֵּ֖ן לְנִידָ֣ה הָיָ֑תָה כָּֽל־מְכַבְּדֶ֤יהָ הִזִּיל֙וּהָ֙ כִּי־רָא֣וּ עֶרְוָתָ֔הּ גַּם־הִ֥יא נֶאֶנְחָ֖ה וַתָּ֥שָׁב אָחֽוֹר׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/9"
                              n="9"/>טֻמְאָתָ֣הּ בְּשׁוּלֶ֗יהָ לֹ֤א זָֽכְרָה֙ אַחֲרִיתָ֔הּ וַתֵּ֣רֶד פְּלָאִ֔ים אֵ֥ין מְנַחֵ֖ם לָ֑הּ רְאֵ֤ה יְהוָה֙ אֶת־עָנְיִ֔י כִּ֥י הִגְדִּ֖יל אוֹיֵֽב׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/10"
                              n="10"/>יָדוֹ֙ פָּ֣רַשׂ צָ֔ר עַ֖ל כָּל־מַחֲמַדֶּ֑יהָ כִּֽי־רָאֲתָ֤ה גוֹיִם֙ בָּ֣אוּ מִקְדָּשָׁ֔הּ אֲשֶׁ֣ר צִוִּ֔יתָה לֹא־יָבֹ֥אוּ בַקָּהָ֖ל לָֽךְ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/11"
                              n="11"/>כָּל־עַמָּ֤הּ נֶאֱנָחִים֙ מְבַקְשִׁ֣ים לֶ֔חֶם נָתְנ֧וּ <tei:choice>
                  <j:written>מחמו<tei:anchor xml:id="note-ref-lamentations-1-11-1"/>דיהם</j:written>
                  <j:read>מַחֲמַדֵּיהֶ֛ם</j:read>
               </tei:choice>בְּאֹ֖כֶל לְהָשִׁ֣יב נָ֑פֶשׁ רְאֵ֤ה יְהוָה֙ וְֽהַבִּ֔יטָה כִּ֥י הָיִ֖יתִי זוֹלֵלָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/12"
                              n="12"/>ל֣וֹא אֲלֵיכֶם֮ כָּל־עֹ֣בְרֵי דֶרֶךְ֒ הַבִּ֣יטוּ וּרְא֔וּ אִם־יֵ֤שׁ מַכְאוֹב֙ כְּמַכְאֹבִ֔י אֲשֶׁ֥ר עוֹלַ֖ל לִ֑י אֲשֶׁר֙ הוֹגָ֣ה יְהוָ֔ה בְּי֖וֹם חֲר֥וֹן אַפּֽוֹ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/13"
                              n="13"/>מִמָּר֛וֹם שָֽׁלַח־אֵ֥שׁ בְּעַצְמֹתַ֖י וַיִּרְדֶּ֑נָּה פָּרַ֨שׂ רֶ֤שֶׁת לְרַגְלַי֙ הֱשִׁיבַ֣נִי אָח֔וֹר נְתָנַ֙נִי֙ שֹֽׁמֵמָ֔ה כָּל־הַיּ֖וֹם דָּוָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/14"
                              n="14"/>נִשְׂקַד֩ עֹ֨ל פְּשָׁעַ֜י בְּיָד֗וֹ יִשְׂתָּֽרְג֛וּ עָל֥וּ עַל־צַוָּארִ֖י הִכְשִׁ֣יל כֹּחִ֑י נְתָנַ֣נִי אֲדֹנָ֔י בִּידֵ֖י לֹא־אוּכַ֥ל קֽוּם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/15"
                              n="15"/>סִלָּ֨ה כָל־אַבִּירַ֤י ׀ אֲדֹנָי֙ בְּקִרְבִּ֔י קָרָ֥א עָלַ֛י מוֹעֵ֖ד לִשְׁבֹּ֣ר בַּחוּרָ֑י גַּ֚ת דָּרַ֣ךְ אֲדֹנָ֔י לִבְתוּלַ֖ת בַּת־יְהוּדָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/16"
                              n="16"/>עַל־אֵ֣לֶּה ׀ אֲנִ֣י בוֹכִיָּ֗ה עֵינִ֤י ׀ עֵינִי֙ יֹ֣רְדָה מַּ֔יִם כִּֽי־רָחַ֥ק מִמֶּ֛נִּי מְנַחֵ֖ם מֵשִׁ֣יב נַפְשִׁ֑י הָי֤וּ בָנַי֙ שֽׁוֹמֵמִ֔ים כִּ֥י גָבַ֖ר אוֹיֵֽב׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/17"
                              n="17"/>פֵּֽרְשָׂ֨ה צִיּ֜וֹן בְּיָדֶ֗יהָ אֵ֤ין מְנַחֵם֙ לָ֔הּ צִוָּ֧ה יְהוָ֛ה לְיַעֲקֹ֖ב סְבִיבָ֣יו צָרָ֑יו הָיְתָ֧ה יְרוּשָׁלַ֛͏ִם לְנִדָּ֖ה בֵּינֵיהֶֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/18"
                              n="18"/>צַדִּ֥יק ה֛וּא יְהוָ֖ה כִּ֣י פִ֣יהוּ מָרִ֑יתִי שִׁמְעוּ־נָ֣א כָל־<tei:choice>
                  <j:written>עמים</j:written>
                  <j:read>הָֽעַמִּ֗ים</j:read>
               </tei:choice>וּרְאוּ֙ מַכְאֹבִ֔י בְּתוּלֹתַ֥י וּבַחוּרַ֖י הָלְכ֥וּ בַשֶּֽׁבִי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/19"
                              n="19"/>קָרָ֤אתִי לַֽמְאַהֲבַי֙ הֵ֣מָּה רִמּ֔וּנִי כֹּהֲנַ֥י וּזְקֵנַ֖י בָּעִ֣יר גָּוָ֑עוּ כִּֽי־בִקְשׁ֥וּ אֹ֙כֶל֙ לָ֔מוֹ וְיָשִׁ֖יבוּ אֶת־נַפְשָֽׁם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/20"
                              n="20"/>רְאֵ֨ה יְהוָ֤ה כִּֽי־צַר־לִי֙ מֵעַ֣י חֳמַרְמָ֔רוּ נֶהְפַּ֤ךְ לִבִּי֙ בְּקִרְבִּ֔י כִּ֥י מָר֖וֹ מָרִ֑יתִי מִח֥וּץ שִׁכְּלָה־חֶ֖רֶב בַּבַּ֥יִת כַּמָּֽוֶת׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/21"
                              n="21"/>שָׁמְע֞וּ כִּ֧י נֶאֱנָחָ֣ה אָ֗נִי אֵ֤ין מְנַחֵם֙ לִ֔י כָּל־אֹ֨יְבַ֜י שָׁמְע֤וּ רָֽעָתִי֙ שָׂ֔שׂוּ כִּ֥י אַתָּ֖ה עָשִׂ֑יתָ הֵבֵ֥אתָ יוֹם־קָרָ֖אתָ וְיִֽהְי֥וּ כָמֽוֹנִי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/1/22"
                              n="22"/>תָּבֹ֨א כָל־רָעָתָ֤ם לְפָנֶ֙יךָ֙ וְעוֹלֵ֣ל לָ֔מוֹ כַּאֲשֶׁ֥ר עוֹלַ֛לְתָּ לִ֖י עַ֣ל כָּל־פְּשָׁעָ֑י כִּֽי־רַבּ֥וֹת אַנְחֹתַ֖י וְלִבִּ֥י דַוָּֽי׃ </tei:p>
            <tei:p type="open-1">
               <tei:milestone unit="chapter"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2"
                              n="2"/>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/1"
                              n="1"/>אֵיכָה֩ יָעִ֨יב בְּאַפּ֤וֹ ׀ אֲדֹנָי֙ אֶת־בַּת־צִיּ֔וֹן הִשְׁלִ֤יךְ מִשָּׁמַ֙יִם֙ אֶ֔רֶץ תִּפְאֶ֖רֶת יִשְׂרָאֵ֑ל וְלֹא־זָכַ֥ר הֲדֹם־רַגְלָ֖יו בְּי֥וֹם אַפּֽוֹ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/2"
                              n="2"/>בִּלַּ֨ע אֲדֹנָ֜י <tei:choice>
                  <j:written>לא</j:written>
                  <j:read>וְלֹ֣א</j:read>
               </tei:choice>חָמַ֗ל אֵ֚ת כָּל־נְא֣וֹת יַעֲקֹ֔ב הָרַ֧ס בְּעֶבְרָת֛וֹ מִבְצְרֵ֥י בַת־יְהוּדָ֖ה הִגִּ֣יעַ לָאָ֑רֶץ חִלֵּ֥ל מַמְלָכָ֖ה וְשָׂרֶֽיהָ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/3"
                              n="3"/>גָּדַ֣ע בָּֽחֳרִי אַ֗ף כֹּ֚ל קֶ֣רֶן יִשְׂרָאֵ֔ל הֵשִׁ֥יב אָח֛וֹר יְמִינ֖וֹ מִפְּנֵ֣י אוֹיֵ֑ב וַיִּבְעַ֤ר בְּיַעֲקֹב֙ כְּאֵ֣שׁ לֶֽהָבָ֔ה אָכְלָ֖ה סָבִֽיב׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/4"
                              n="4"/>דָּרַ֨ךְ קַשְׁתּ֜וֹ כְּאוֹיֵ֗ב נִצָּ֤ב יְמִינוֹ֙ כְּצָ֔ר וַֽיַּהֲרֹ֔ג כֹּ֖ל מַחֲמַדֵּי־עָ֑יִן בְּאֹ֙הֶל֙ בַּת־צִיּ֔וֹן שָׁפַ֥ךְ כָּאֵ֖שׁ חֲמָתֽוֹ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/5"
                              n="5"/>הָיָ֨ה אֲדֹנָ֤י ׀ כְּאוֹיֵב֙ בִּלַּ֣ע יִשְׂרָאֵ֔ל בִּלַּע֙ כָּל־אַרְמְנוֹתֶ֔יהָ שִׁחֵ֖ת מִבְצָרָ֑יו וַיֶּ֙רֶב֙ בְּבַת־יְהוּדָ֔ה תַּאֲנִיָּ֖ה וַאֲנִיָּֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/6"
                              n="6"/>וַיַּחְמֹ֤ס כַּגַּן֙ שֻׂכּ֔וֹ שִׁחֵ֖ת מוֹעֲד֑וֹ שִׁכַּ֨ח יְהוָ֤ה ׀ בְּצִיּוֹן֙ מוֹעֵ֣ד וְשַׁבָּ֔ת וַיִּנְאַ֥ץ בְּזַֽעַם־אַפּ֖וֹ מֶ֥לֶךְ וְכֹהֵֽן׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/7"
                              n="7"/>זָנַ֨ח אֲדֹנָ֤י ׀ מִזְבְּחוֹ֙ נִאֵ֣ר מִקְדָּשׁ֔וֹ הִסְגִּיר֙ בְּיַד־אוֹיֵ֔ב חוֹמֹ֖ת אַרְמְנוֹתֶ֑יהָ ק֛וֹל נָתְנ֥וּ בְּבֵית־יְהוָ֖ה כְּי֥וֹם מוֹעֵֽד׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/8"
                              n="8"/>חָשַׁ֨ב יְהוָ֤ה ׀ לְהַשְׁחִית֙ חוֹמַ֣ת בַּת־צִיּ֔וֹן נָ֣טָה קָ֔ו לֹא־הֵשִׁ֥יב יָד֖וֹ מִבַּלֵּ֑עַ וַיּֽ͏ַאֲבֶל־חֵ֥ל וְחוֹמָ֖ה יַחְדָּ֥ו אֻמְלָֽלוּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/9"
                              n="9"/>טָבְע֤וּ בָאָ֙רֶץ֙ שְׁעָרֶ֔יהָ אִבַּ֥ד וְשִׁבַּ֖ר בְּרִיחֶ֑יהָ מַלְכָּ֨הּ וְשָׂרֶ֤יהָ בַגּוֹיִם֙ אֵ֣ין תּוֹרָ֔ה גַּם־נְבִיאֶ֕יהָ לֹא־מָצְא֥וּ חָז֖וֹן מֵיְהוָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/10"
                              n="10"/>יֵשְׁב֨וּ לָאָ֤רֶץ יִדְּמוּ֙ זִקְנֵ֣י בַת־צִיּ֔וֹן הֶֽעֱל֤וּ עָפָר֙ עַל־רֹאשָׁ֔ם חָגְר֖וּ שַׂקִּ֑ים הוֹרִ֤ידוּ לָאָ֙רֶץ֙ רֹאשָׁ֔ן בְּתוּלֹ֖ת יְרוּשָׁלָֽ͏ִם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/11"
                              n="11"/>כָּל֨וּ בַדְּמָע֤וֹת עֵינַי֙ חֳמַרְמְר֣וּ מֵעַ֔י נִשְׁפַּ֤ךְ לָאָ֙רֶץ֙ כְּבֵדִ֔י עַל־שֶׁ֖בֶר בַּת־עַמִּ֑י בֵּֽעָטֵ֤ף עוֹלֵל֙ וְיוֹנֵ֔ק בִּרְחֹב֖וֹת קִרְיָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/12"
                              n="12"/>לְאִמֹּתָם֙ יֹֽאמְר֔וּ אַיֵּ֖ה דָּגָ֣ן וָיָ֑יִן בְּהִֽתְעַטְּפָ֤ם כֶּֽחָלָל֙ בִּרְחֹב֣וֹת עִ֔יר בְּהִשְׁתַּפֵּ֣ךְ נַפְשָׁ֔ם אֶל־חֵ֖יק אִמֹּתָֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/13"
                              n="13"/>מָֽה־אֲעִידֵ֞ךְ מָ֣ה אֲדַמֶּה־לָּ֗ךְ הַבַּת֙ יְר֣וּשָׁלִַ֔ם מָ֤ה אַשְׁוֶה־לָּךְ֙ וַאֲנַֽחֲמֵ֔ךְ בְּתוּלַ֖ת בַּת־צִיּ֑וֹן כִּֽי־גָד֥וֹל כַּיָּ֛ם שִׁבְרֵ֖ךְ מִ֥י יִרְפָּא־לָֽךְ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/14"
                              n="14"/>נְבִיאַ֗יִךְ חָ֤זוּ לָךְ֙ שָׁ֣וְא וְתָפֵ֔ל וְלֹֽא־גִלּ֥וּ עַל־עֲוֺנֵ֖ךְ לְהָשִׁ֣יב <tei:choice>
                  <j:written>שביתך</j:written>
                  <j:read>שְׁבוּתֵ֑ךְ</j:read>
               </tei:choice>וַיֶּ֣חֱזוּ לָ֔ךְ מַשְׂא֥וֹת שָׁ֖וְא וּמַדּוּחִֽים׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/15"
                              n="15"/>סָֽפְק֨וּ עָלַ֤יִךְ כַּפַּ֙יִם֙ כָּל־עֹ֣בְרֵי דֶ֔רֶךְ שָֽׁרְקוּ֙ וַיָּנִ֣עוּ רֹאשָׁ֔ם עַל־בַּ֖ת יְרוּשָׁלָ֑͏ִם הֲזֹ֣את הָעִ֗יר שֶׁיֹּֽאמְרוּ֙ כְּלִ֣ילַת יֹ֔פִי מָשׂ֖וֹשׂ לְכָל־הָאָֽרֶץ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/16"
                              n="16"/>פָּצ֨וּ עָלַ֤יִךְ פִּיהֶם֙ כָּל־א֣וֹיְבַ֔יִךְ שָֽׁרְקוּ֙ וַיַּֽחַרְקוּ־שֵׁ֔ן אָמְר֖וּ בִּלָּ֑עְנוּ אַ֣ךְ זֶ֥ה הַיּ֛וֹם שֶׁקִּוִּינֻ֖הוּ מָצָ֥אנוּ רָאִֽינוּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/17"
                              n="17"/>עָשָׂ֨ה יְהוָ֜ה אֲשֶׁ֣ר זָמָ֗ם בִּצַּ֤ע אֶמְרָתוֹ֙ אֲשֶׁ֣ר צִוָּ֣ה מִֽימֵי־קֶ֔דֶם הָרַ֖ס וְלֹ֣א חָמָ֑ל וַיְשַׂמַּ֤ח עָלַ֙יִךְ֙ אוֹיֵ֔ב הֵרִ֖ים קֶ֥רֶן צָרָֽיִךְ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/18"
                              n="18"/>צָעַ֥ק לִבָּ֖ם אֶל־אֲדֹנָ֑י חוֹמַ֣ת בַּת־צִ֠יּוֹן הוֹרִ֨ידִי כַנַּ֤חַל דִּמְעָה֙ יוֹמָ֣ם וָלַ֔יְלָה אַֽל־תִּתְּנִ֤י פוּגַת֙ לָ֔ךְ אַל־תִּדֹּ֖ם בַּת־עֵינֵֽךְ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/19"
                              n="19"/>ק֣וּמִי ׀ רֹ֣נִּי <tei:choice>
                  <j:written>בליל</j:written>
                  <j:read>בַלַּ֗יְלָה</j:read>
               </tei:choice>לְרֹאשׁ֙ אַשְׁמֻר֔וֹת שִׁפְכִ֤י כַמַּ֙יִם֙ לִבֵּ֔ךְ נֹ֖כַח פְּנֵ֣י אֲדֹנָ֑י שְׂאִ֧י אֵלָ֣יו כַּפַּ֗יִךְ עַל־נֶ֙פֶשׁ֙ עֽוֹלָלַ֔יִךְ הָעֲטוּפִ֥ים בְּרָעָ֖ב בְּרֹ֥אשׁ כָּל־חוּצֽוֹת׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/20"
                              n="20"/>רְאֵ֤ה יְהוָה֙ וְֽהַבִּ֔יטָה לְמִ֖י עוֹלַ֣לְתָּ כֹּ֑ה אִם־תֹּאכַ֨לְנָה נָשִׁ֤ים פִּרְיָם֙ עֹלֲלֵ֣י טִפֻּחִ֔ים אִם־יֵהָרֵ֛ג בְּמִקְדַּ֥שׁ אֲדֹנָ֖י כֹּהֵ֥ן וְנָבִֽיא׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/21"
                              n="21"/>שָׁכְב֨וּ לָאָ֤רֶץ חוּצוֹת֙ נַ֣עַר וְזָקֵ֔ן בְּתוּלֹתַ֥י וּבַחוּרַ֖י נָפְל֣וּ בֶחָ֑רֶב הָרַגְ֙תָּ֙ בְּי֣וֹם אַפֶּ֔ךָ טָבַ֖חְתָּ לֹ֥א חָמָֽלְתָּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/2/22"
                              n="22"/>תִּקְרָא֩ כְי֨וֹם מוֹעֵ֤ד מְגוּרַי֙ מִסָּבִ֔יב וְלֹ֥א הָיָ֛ה בְּי֥וֹם אַף־יְהוָ֖ה פָּלִ֣יט וְשָׂרִ֑יד אֲשֶׁר־טִפַּ֥חְתִּי וְרִבִּ֖יתִי אֹיְבִ֥י כִלָּֽם׃ </tei:p>
            <tei:p type="open-1">
               <tei:milestone unit="chapter"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3"
                              n="3"/>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/1"
                              n="1"/>אֲנִ֤י הַגֶּ֙בֶר֙ רָאָ֣ה עֳנִ֔י בְּשֵׁ֖בֶט עֶבְרָתֽוֹ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/2"
                              n="2"/>אוֹתִ֥י נָהַ֛ג וַיֹּלַ֖ךְ חֹ֥שֶׁךְ וְלֹא־אֽוֹר׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/3"
                              n="3"/>אַ֣ךְ בִּ֥י יָשֻׁ֛ב יַהֲפֹ֥ךְ יָד֖וֹ כָּל־הַיּֽוֹם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/4"
                              n="4"/>בִּלָּ֤ה בְשָׂרִי֙ וְעוֹרִ֔י שִׁבַּ֖ר עַצְמוֹתָֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/5"
                              n="5"/>בָּנָ֥ה עָלַ֛י וַיַּקַּ֖ף רֹ֥אשׁ וּתְלָאָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/6"
                              n="6"/>בְּמַחֲשַׁכִּ֥ים הוֹשִׁיבַ֖נִי כְּמֵתֵ֥י עוֹלָֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/7"
                              n="7"/>גָּדַ֧ר בַּעֲדִ֛י וְלֹ֥א אֵצֵ֖א הִכְבִּ֥יד נְחָשְׁתִּֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/8"
                              n="8"/>גַּ֣ם כִּ֤י אֶזְעַק֙ וַאֲשַׁוֵּ֔עַ שָׂתַ֖ם תְּפִלָּתִֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/9"
                              n="9"/>גָּדַ֤ר דְּרָכַי֙ בְּגָזִ֔ית נְתִיבֹתַ֖י עִוָּֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/10"
                              n="10"/>דֹּ֣ב אֹרֵ֥ב הוּא֙ לִ֔י <tei:choice>
                  <j:written>אריה</j:written>
                  <j:read>אֲרִ֖י</j:read>
               </tei:choice>בְּמִסְתָּרִֽים׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/11"
                              n="11"/>דְּרָכַ֥י סוֹרֵ֛ר וַֽיְפַשְּׁחֵ֖נִי שָׂמַ֥נִי שֹׁמֵֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/12"
                              n="12"/>דָּרַ֤ךְ קַשְׁתוֹ֙ וַיַּצִּיבֵ֔נִי כַּמַּטָּרָ֖א לַחֵֽץ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/13"
                              n="13"/>הֵבִיא֙ בְּכִלְיוֹתָ֔י בְּנֵ֖י אַשְׁפָּתֽוֹ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/14"
                              n="14"/>הָיִ֤יתִי שְּׂחֹק֙ לְכָל־עַמִּ֔י נְגִינָתָ֖ם כָּל־הַיּֽוֹם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/15"
                              n="15"/>הִשְׂבִּיעַ֥נִי בַמְּרוֹרִ֖ים הִרְוַ֥נִי לַעֲנָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/16"
                              n="16"/>וַיַּגְרֵ֤ס בֶּֽחָצָץ֙ שִׁנָּ֔י הִכְפִּישַׁ֖נִי בָּאֵֽפֶר׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/17"
                              n="17"/>וַתִּזְנַ֧ח מִשָּׁל֛וֹם נַפְשִׁ֖י נָשִׁ֥יתִי טוֹבָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/18"
                              n="18"/>וָאֹמַר֙ אָבַ֣ד נִצְחִ֔י וְתוֹחַלְתִּ֖י מֵיְהוָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/19"
                              n="19"/>זְכָר־עָנְיִ֥י וּמְרוּדִ֖י לַעֲנָ֥ה וָרֹֽאשׁ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/20"
                              n="20"/>זָכ֣וֹר תִּזְכּ֔וֹר <tei:choice>
                  <j:written>ותשיח</j:written>
                  <j:read>וְתָשׁ֥וֹחַ</j:read>
               </tei:choice>עָלַ֖י נַפְשִֽׁי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/21"
                              n="21"/>זֹ֛את אָשִׁ֥יב אֶל־לִבִּ֖י עַל־כֵּ֥ן אוֹחִֽיל׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/22"
                              n="22"/>חַֽסְדֵ֤י יְהוָה֙ כִּ֣י לֹא־תָ֔מְנוּ כִּ֥י לֹא־כָל֖וּ רַחֲמָֽיו׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/23"
                              n="23"/>חֲדָשִׁים֙ לַבְּקָרִ֔ים רַבָּ֖ה אֱמוּנָתֶֽךָ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/24"
                              n="24"/>חֶלְקִ֤י יְהוָה֙ אָמְרָ֣ה נַפְשִׁ֔י עַל־כֵּ֖ן אוֹחִ֥יל לֽוֹ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/25"
                              n="25"/>ט֤וֹב יְהוָה֙ לְקֹוָ֔ו לְנֶ֖פֶשׁ תִּדְרְשֶֽׁנּוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/26"
                              n="26"/>ט֤וֹב וְיָחִיל֙ וְדוּמָ֔ם לִתְשׁוּעַ֖ת יְהוָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/27"
                              n="27"/>ט֣וֹב לַגֶּ֔בֶר כִּֽי־יִשָּׂ֥א עֹ֖ל בִּנְעוּרָֽיו׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/28"
                              n="28"/>יֵשֵׁ֤ב בָּדָד֙ וְיִדֹּ֔ם כִּ֥י נָטַ֖ל עָלָֽיו׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/29"
                              n="29"/>יִתֵּ֤ן בֶּֽעָפָר֙ פִּ֔יהוּ אוּלַ֖י יֵ֥שׁ תִּקְוָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/30"
                              n="30"/>יִתֵּ֧ן לְמַכֵּ֛הוּ לֶ֖חִי יִשְׂבַּ֥ע בְּחֶרְפָּֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/31"
                              n="31"/>כִּ֣י לֹ֥א יִזְנַ֛ח לְעוֹלָ֖ם אֲדֹנָֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/32"
                              n="32"/>כִּ֣י אִם־הוֹגָ֔ה וְרִחַ֖ם כְּרֹ֥ב <tei:choice>
                  <j:written>חסדו</j:written>
                  <j:read>חֲסָדָֽיו׃</j:read>
               </tei:choice>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/33"
                              n="33"/>כִּ֣י לֹ֤א עִנָּה֙ מִלִבּ֔וֹ וַיַּגֶּ֖ה בְ<tei:anchor xml:id="note-ref-lamentations-3-33-1"/>נֵי־אִֽישׁ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/34"
                              n="34"/>לְדַכֵּא֙ תַּ֣חַת רַגְלָ֔יו כֹּ֖ל אֲסִ֥ירֵי אָֽרֶץ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/35"
                              n="35"/>לְהַטּוֹת֙ מִשְׁפַּט־גָּ֔בֶר נֶ֖גֶד פְּנֵ֥י עֶלְיֽוֹן׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/36"
                              n="36"/>לְעַוֵּ֤ת אָדָם֙ בְּרִיב֔וֹ אֲדֹנָ֖י לֹ֥א רָאָֽה׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/37"
                              n="37"/>מִ֣י זֶ֤ה אָמַר֙ וַתֶּ֔הִי אֲדֹנָ֖י לֹ֥א צִוָּֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/38"
                              n="38"/>מִפִּ֤י עֶלְיוֹן֙ לֹ֣א תֵצֵ֔א הָרָע֖וֹת וְהַטּֽוֹב׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/39"
                              n="39"/>מַה־יִּתְאוֹנֵן֙ אָדָ֣ם חָ֔י גֶּ֖בֶר עַל־<tei:choice>
                  <j:written>חטאו</j:written>
                  <j:read>חֲטָאָֽיו׃</j:read>
               </tei:choice>
            </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/40"
                              n="40"/>נַחְפְּשָׂ֤ה דְרָכֵ֙ינוּ֙ וְֽנַחְקֹ֔רָה וְנָשׁ֖וּבָה עַד־יְהוָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/41"
                              n="41"/>נִשָּׂ֤א לְבָבֵ֙נוּ֙ אֶל־כַּפָּ֔יִם אֶל־אֵ֖ל בַּשָּׁמָֽיִם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/42"
                              n="42"/>נַ֤חְנוּ פָשַׁ֙עְנוּ֙ וּמָרִ֔ינוּ אַתָּ֖ה לֹ֥א סָלָֽחְתָּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/43"
                              n="43"/>סַכֹּ֤תָה בָאַף֙ וַֽתִּרְדְּפֵ֔נוּ הָרַ֖גְתָּ לֹ֥א חָמָֽלְתָּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/44"
                              n="44"/>סַכּ֤וֹתָה בֶֽעָנָן֙ לָ֔ךְ מֵעֲב֖וֹר תְּפִלָּֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/45"
                              n="45"/>סְחִ֧י וּמָא֛וֹס תְּשִׂימֵ֖נוּ בְּקֶ֥רֶב הָעַמִּֽים׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/46"
                              n="46"/>פָּצ֥וּ עָלֵ֛ינוּ פִּיהֶ֖ם כָּל־אֹיְבֵֽינוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/47"
                              n="47"/>פַּ֧חַד וָפַ֛חַת הָ֥יָה לָ֖נוּ הַשֵּׁ֥את וְהַשָּֽׁבֶר׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/48"
                              n="48"/>פַּלְגֵי־מַ֙יִם֙ תֵּרַ֣ד עֵינִ֔י עַל־שֶׁ֖בֶר בַּת־עַמִּֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/49"
                              n="49"/>עֵינִ֧י נִגְּרָ֛ה וְלֹ֥א תִדְמֶ֖ה מֵאֵ֥ין הֲפֻגֽוֹת׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/50"
                              n="50"/>עַד־יַשְׁקִ֣יף וְיֵ֔רֶא יְהוָ֖ה מִשָּׁמָֽיִם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/51"
                              n="51"/>עֵינִי֙ עֽוֹלְלָ֣ה לְנַפְשִׁ֔י מִכֹּ֖ל בְּנ֥וֹת עִירִֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/52"
                              n="52"/>צ֥וֹד צָד֛וּנִי כַּצִּפּ֖וֹר אֹיְבַ֥י חִנָּֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/53"
                              n="53"/>צָֽמְת֤וּ בַבּוֹר֙ חַיָּ֔י וַיַּדּוּ־אֶ֖בֶן בִּֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/54"
                              n="54"/>צָֽפוּ־מַ֥יִם עַל־רֹאשִׁ֖י אָמַ֥רְתִּי נִגְזָֽרְתִּי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/55"
                              n="55"/>קָרָ֤אתִי שִׁמְךָ֙ יְהוָ֔ה מִבּ֖וֹר תַּחְתִּיּֽוֹת׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/56"
                              n="56"/>קוֹלִ֖י שָׁמָ֑עְתָּ אַל־תַּעְלֵ֧ם אָזְנְךָ֛ לְרַוְחָתִ֖י לְשַׁוְעָתִֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/57"
                              n="57"/>קָרַ֙בְתָּ֙ בְּי֣וֹם אֶקְרָאֶ֔ךָּ אָמַ֖רְתָּ אַל־תִּירָֽא׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/58"
                              n="58"/>רַ֧בְתָּ אֲדֹנָ֛י רִיבֵ֥י נַפְשִׁ֖י גָּאַ֥לְתָּ חַיָּֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/59"
                              n="59"/>רָאִ֤יתָה יְהוָה֙ עַוָּ֣תָתִ֔י שָׁפְטָ֖ה מִשְׁפָּטִֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/60"
                              n="60"/>רָאִ֙יתָה֙ כָּל־נִקְמָתָ֔ם כָּל־מַחְשְׁבֹתָ֖ם לִֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/61"
                              n="61"/>שָׁמַ֤עְתָּ חֶרְפָּתָם֙ יְהוָ֔ה כָּל־מַחְשְׁבֹתָ֖ם עָלָֽי׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/62"
                              n="62"/>שִׂפְתֵ֤י קָמַי֙ וְהֶגְיוֹנָ֔ם עָלַ֖י כָּל־הַיּֽוֹם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/63"
                              n="63"/>שִׁבְתָּ֤ם וְקִֽימָתָם֙ הַבִּ֔יטָה אֲנִ֖י מַנְגִּינָתָֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/64"
                              n="64"/>תָּשִׁ֨יב לָהֶ֥ם גְּמ֛וּל יְהוָ֖ה כְּמַעֲשֵׂ֥ה יְדֵיהֶֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/65"
                              n="65"/>תִּתֵּ֤ן לָהֶם֙ מְגִנַּת־לֵ֔ב תַּאֲלָֽתְךָ֖ לָהֶֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/3/66"
                              n="66"/>תִּרְדֹּ֤ף בְּאַף֙ וְתַשְׁמִידֵ֔ם מִתַּ֖חַת שְׁמֵ֥י יְהוָֽה׃ </tei:p>
            <tei:p type="open-1">
               <tei:milestone unit="chapter"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4"
                              n="4"/>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/1"
                              n="1"/>אֵיכָה֙ יוּעַ֣ם זָהָ֔ב יִשְׁנֶ֖א הַכֶּ֣תֶם הַטּ֑וֹב תִּשְׁתַּפֵּ֙כְנָה֙ אַבְנֵי־קֹ֔דֶשׁ בְּרֹ֖אשׁ כָּל־חוּצֽוֹת׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/2"
                              n="2"/>בְּנֵ֤י צִיּוֹן֙ הַיְקָרִ֔ים הַמְסֻלָּאִ֖ים בַּפָּ֑ז אֵיכָ֤ה נֶחְשְׁבוּ֙ לְנִבְלֵי־חֶ֔רֶשׂ מַעֲשֵׂ֖ה יְדֵ֥י יוֹצֵֽר׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/3"
                              n="3"/>גַּם־<tei:choice>
                  <j:written>תנין</j:written>
                  <j:read>תַּנִּים֙</j:read>
               </tei:choice>חָ֣לְצוּ שַׁ֔ד הֵינִ֖יקוּ גּוּרֵיהֶ֑ן בַּת־עַמִּ֣י לְאַכְזָ֔ר <j:written>כי</j:written>
               <tei:choice>
                  <j:written>ענים</j:written>
                  <j:read>כַּיְעֵנִ֖ים</j:read>
               </tei:choice>בַּמִּדְבָּֽר׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/4"
                              n="4"/>דָּבַ֨ק לְשׁ֥וֹן יוֹנֵ֛ק אֶל־חִ<tei:anchor xml:id="note-ref-lamentations-4-4-1"/>כּ֖וֹ בַּצָּמָ֑א עֽוֹלָלִים֙ שָׁ֣אֲלוּ לֶ֔חֶם פֹּרֵ֖שׂ אֵ֥ין לָהֶֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/5"
                              n="5"/>הָאֹֽכְלִים֙ לְמַ֣עֲדַנִּ֔ים נָשַׁ֖מּוּ בַּחוּצ֑וֹת הָאֱמֻנִים֙ עֲלֵ֣י תוֹלָ֔ע חִבְּק֖וּ אַשְׁפַּתּֽוֹת׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/6"
                              n="6"/>וַיִּגְדַּל֙ עֲוֺ֣ן בַּת־עַמִּ֔י מֵֽחַטַּ֖את סְדֹ֑ם הַֽהֲפוּכָ֣ה כְמוֹ־רָ֔גַע וְלֹא־חָ֥לוּ בָ֖הּ יָדָֽיִם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/7"
                              n="7"/>זַכּ֤וּ נְזִירֶ֙יהָ֙ מִשֶּׁ֔<tei:anchor xml:id="note-ref-lamentations-4-7-1"/>לֶג צַח֖וּ מֵחָלָ֑ב אָ֤דְמוּ עֶ֙צֶם֙ מִפְּנִינִ֔ים סַפִּ֖יר גִּזְרָתָֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/8"
                              n="8"/>חָשַׁ֤ךְ מִשְּׁחוֹר֙ תָּֽאֳרָ֔ם לֹ֥א נִכְּר֖וּ בַּחוּצ֑וֹת צָפַ֤ד עוֹרָם֙ עַל־עַצְמָ֔ם יָבֵ֖שׁ הָיָ֥ה כָעֵֽץ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/9"
                              n="9"/>טוֹבִ֤ים הָיוּ֙ חַלְלֵי־חֶ֔רֶב מֵֽחַלְלֵ֖י רָעָ֑ב שֶׁ֣הֵ֤ם יָז֙וּבוּ֙ מְדֻקָּרִ֔ים מִתְּנוּבֹ֖ת שָׂדָֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/10"
                              n="10"/>יְדֵ֗י נָשִׁים֙ רַחֲמָ֣נִיּ֔וֹת בִּשְּׁל֖וּ יַלְדֵיהֶ֑ן הָי֤וּ לְבָרוֹת֙ לָ֔מוֹ בְּשֶׁ֖בֶר בַּת־עַמִּֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/11"
                              n="11"/>כִּלָּ֤ה יְהוָה֙ אֶת־חֲמָת֔וֹ שָׁפַ֖ךְ חֲר֣וֹן אַפּ֑וֹ וַיַּצֶּת־אֵ֣שׁ בְּצִיּ֔וֹן וַתֹּ֖אכַל יְסוֹדֹתֶֽיהָ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/12"
                              n="12"/>לֹ֤א הֶאֱמִ֙ינוּ֙ מַלְכֵי־אֶ֔רֶץ <tei:choice>
                  <j:written>וכל</j:written>
                  <j:read>כֹּ֖ל</j:read>
               </tei:choice>יֹשְׁבֵ֣י תֵבֵ֑ל כִּ֤י יָבֹא֙ צַ֣ר וְאוֹיֵ֔ב בְּשַׁעֲרֵ֖י יְרוּשָׁלָֽ͏ִם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/13"
                              n="13"/>מֵֽחַטֹּ֣את נְבִיאֶ֔יהָ עֲוֺנ֖וֹת כֹּהֲנֶ֑יהָ הַשֹּׁפְכִ֥ים בְּקִרְבָּ֖הּ דַּ֥ם צַדִּיקִֽים׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/14"
                              n="14"/>נָע֤וּ עִוְרִים֙ בַּֽחוּצ֔וֹת נְגֹֽאֲל֖וּ בַּדָּ֑ם בְּלֹ֣א יֽוּכְל֔וּ יִגְּע֖וּ בִּלְבֻשֵׁיהֶֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/15"
                              n="15"/>ס֣וּרוּ טָמֵ֞א קָ֣רְאוּ לָ֗מוֹ ס֤וּרוּ ס֙וּרוּ֙ אַל־תִּגָּ֔עוּ כִּ֥י נָצ֖וּ גַּם־נָ֑עוּ אָֽמְרוּ֙ בַּגּוֹיִ֔ם לֹ֥א יוֹסִ֖יפוּ לָגֽוּר׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/16"
                              n="16"/>פְּנֵ֤י יְהוָה֙ חִלְּקָ֔ם לֹ֥א יוֹסִ֖יף לְהַבִּיטָ֑ם פְּנֵ֤י כֹהֲנִים֙ לֹ֣א נָשָׂ֔אוּ <tei:choice>
                  <j:written>זקנים</j:written>
                  <j:read>ו<tei:anchor xml:id="note-ref-lamentations-4-16-1"/>זְקֵנִ֖ים</j:read>
               </tei:choice>לֹ֥א חָנָֽנוּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/17"
                              n="17"/>
               <tei:choice>
                  <j:written>עודינה</j:written>
                  <j:read>עוֹדֵ֙ינוּ֙</j:read>
               </tei:choice>תִּכְלֶ֣ינָה עֵינֵ֔ינוּ אֶל־עֶזְרָתֵ֖נוּ הָ֑בֶל בְּצִפִּיָּתֵ֣נוּ צִפִּ֔ינוּ אֶל־גּ֖וֹי לֹ֥א יוֹשִֽׁעַ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/18"
                              n="18"/>צָד֣וּ צְעָדֵ֔ינוּ מִלֶּ֖כֶת בִּרְחֹבֹתֵ֑ינוּ קָרַ֥ב קִצֵּ֛ינוּ מָלְא֥וּ יָמֵ֖ינוּ כִּי־בָ֥א קִצֵּֽינוּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/19"
                              n="19"/>קַלִּ֤ים הָיוּ֙ רֹדְפֵ֔ינוּ מִנִּשְׁרֵ֖י שָׁמָ֑יִם עַל־הֶהָרִ֣ים דְּלָקֻ֔נוּ בַּמִּדְבָּ֖ר אָ֥רְבוּ לָֽנוּ׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/20"
                              n="20"/>ר֤וּחַ אַפֵּ֙ינוּ֙ מְשִׁ֣יחַ יְהוָ֔ה נִלְכַּ֖ד בִּשְׁחִיתוֹתָ֑ם אֲשֶׁ֣ר אָמַ֔רְנוּ בְּצִלּ֖וֹ נִֽחְיֶ֥ה בַגּוֹיִֽם׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/21"
                              n="21"/>שִׂ֤ישִׂי וְשִׂמְחִי֙ בַּת־אֱד֔וֹם <tei:choice>
                  <j:written>יושבתי</j:written>
                  <j:read>יוֹשֶׁ֖בֶת</j:read>
               </tei:choice>בְּאֶ֣רֶץ ע֑וּץ גַּם־עָלַ֙יִךְ֙ תַּעֲבָר־כּ֔וֹס תִּשְׁכְּרִ֖י וְתִתְעָרִֽי׃ </tei:p>
            <tei:p type="close-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/4/22"
                              n="22"/>תַּם־עֲוֺנֵךְ֙ בַּת־צִיּ֔וֹן לֹ֥א יוֹסִ֖יף לְהַגְלוֹתֵ֑ךְ פָּקַ֤ד עֲוֺנֵךְ֙ בַּת־אֱד֔וֹם גִּלָּ֖ה עַל־חַטֹּאתָֽיִךְ׃ </tei:p>
            <tei:p type="open-1">
               <tei:milestone unit="chapter"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5"
                              n="5"/>
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/1"
                              n="1"/>זְכֹ֤ר יְהוָה֙ מֶֽה־הָ֣יָה לָ֔נוּ <tei:choice>
                  <j:written>הביט</j:written>
                  <j:read>הַבִּ֖יטָה</j:read>
               </tei:choice>וּרְאֵ֥ה אֶת־חֶרְפָּתֵֽנוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/2"
                              n="2"/>נַחֲלָתֵ֙נוּ֙ נֶֽהֶפְכָ֣ה לְזָרִ֔ים בָּתֵּ֖ינוּ לְנָכְרִֽים׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/3"
                              n="3"/>יְתוֹמִ֤ים הָיִ֙ינוּ֙ <tei:choice>
                  <j:written>אין</j:written>
                  <j:read>וְאֵ֣ין</j:read>
               </tei:choice>אָ֔ב אִמֹּתֵ֖ינוּ כְּאַלְמָנֽוֹת׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/4"
                              n="4"/>מֵימֵ֙ינוּ֙ בְּכֶ֣סֶף שָׁתִ֔ינוּ עֵצֵ֖ינוּ בִּמְחִ֥יר יָבֹֽאוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/5"
                              n="5"/>עַ֤ל צַוָּארֵ֙נוּ֙ נִרְדָּ֔פְנוּ יָגַ֖עְנוּ <tei:choice>
                  <j:written>לא</j:written>
                  <j:read>וְלֹ֥א</j:read>
               </tei:choice>הֽוּנַ֖ח לָֽנוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/6"
                              n="6"/>מִצְרַ֙יִם֙ נָתַ֣נּוּ יָ֔ד אַשּׁ֖וּר לִשְׂבֹּ֥עַֽ לָֽחֶם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/7"
                              n="7"/>אֲבֹתֵ֤ינוּ חָֽטְאוּ֙ <tei:choice>
                  <j:written>אינם</j:written>
                  <j:read>וְאֵינָ֔ם</j:read>
               </tei:choice>
               <tei:choice>
                  <j:written>אנחנו</j:written>
                  <j:read>וַאֲנַ֖חְנוּ</j:read>
               </tei:choice>עֲוֺנֹתֵיהֶ֥ם סָבָֽלְנוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/8"
                              n="8"/>עֲבָדִים֙ מָ֣שְׁלוּ בָ֔נוּ פֹּרֵ֖ק אֵ֥ין מִיָּדָֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/9"
                              n="9"/>בְּנַפְשֵׁ֙נוּ֙ נָבִ֣יא לַחְמֵ֔נוּ מִפְּנֵ֖י חֶ֥רֶב הַמִּדְבָּֽר׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/10"
                              n="10"/>עוֹרֵ֙נוּ֙ כְּתַנּ֣וּר נִכְמָ֔רוּ מִפְּנֵ֖י זַלְעֲפ֥וֹת רָעָֽב׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/11"
                              n="11"/>נָשִׁים֙ בְּצִיּ֣וֹן עִנּ֔וּ בְּתֻלֹ֖ת בְּעָרֵ֥י יְהוּדָֽה׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/12"
                              n="12"/>שָׂרִים֙ בְּיָדָ֣ם נִתְל֔וּ פְּנֵ֥י זְקֵנִ֖ים לֹ֥א נֶהְדָּֽרוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/13"
                              n="13"/>בַּחוּרִים֙ טְח֣וֹן נָשָׂ֔אוּ וּנְעָרִ֖ים בָּעֵ֥ץ כָּשָֽׁלוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/14"
                              n="14"/>זְקֵנִים֙ מִשַּׁ֣עַר שָׁבָ֔תוּ בַּחוּרִ֖ים מִנְּגִינָתָֽם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/15"
                              n="15"/>שָׁבַת֙ מְשׂ֣וֹשׂ לִבֵּ֔נוּ נֶהְפַּ֥ךְ לְאֵ֖בֶל מְחֹלֵֽנוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/16"
                              n="16"/>נָֽפְלָה֙ עֲטֶ֣רֶת רֹאשֵׁ֔נוּ אֽוֹי־נָ֥א לָ֖נוּ כִּ֥י חָטָֽאנוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/17"
                              n="17"/>עַל־זֶ֗ה הָיָ֤ה דָוֶה֙ לִבֵּ֔נוּ עַל־אֵ֖לֶּה חָשְׁכ֥וּ עֵינֵֽינוּ׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/18"
                              n="18"/>עַ֤ל הַר־צִיּוֹן֙ שֶׁשָּׁמֵ֔ם שׁוּעָלִ֖ים הִלְּכוּ־בֽוֹ׃ </tei:p>
            <tei:p type="open-1">
               <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/19"
                              n="19"/>אַתָּ֤ה יְהוָה֙ לְעוֹלָ֣ם תֵּשֵׁ֔ב כִּסְאֲךָ֖ לְדֹ֥ר וָדֽוֹר׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/20"
                              n="20"/>לָ֤מָּה לָנֶ֙צַח֙ תִּשְׁכָּחֵ֔נוּ תַּֽעַזְבֵ֖נוּ לְאֹ֥רֶךְ יָמִֽים׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/21"
                              n="21"/>הֲשִׁיבֵ֨נוּ יְהוָ֤ה ׀ אֵלֶ֙יךָ֙ <tei:choice>
                  <j:written>ונשוב</j:written>
                  <j:read>וְֽנָשׁ֔וּבָה</j:read>
               </tei:choice>חַדֵּ֥שׁ יָמֵ֖ינוּ כְּקֶֽדֶם׃ <tei:milestone unit="verse"
                              corresp="urn:x-opensiddur:text:bible:lamentations/5/22"
                              n="22"/>כִּ֚י אִם־מָאֹ֣ס מְאַסְתָּ֔נוּ קָצַ֥פְתָּ עָלֵ֖ינוּ עַד־מְאֹֽד׃ </tei:p>
         </tei:div>
      </tei:body>
   </tei:text>
